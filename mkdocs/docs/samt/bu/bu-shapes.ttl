            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/common-ap-no/id> ] ;
    sh:targetClass dcterms:Frequency .

dcterms:ProvenanceStatement a sh:NodeShape ;
    rdfs:comment "Ein provenienserklæring." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
