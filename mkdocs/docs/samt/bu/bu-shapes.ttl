dcat:CatalogRecord a sh:NodeShape ;
    rdfs:comment "Ein katalogpost som beskriv ein ressurs i katalogen." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "Dato ressursen vart første gong publisert (dct:issued)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:issued ],
        [ sh:datatype rdf:langString ;
            sh:description "Namn/tittel på ressursen (dct:title)." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path dcterms:title ],
        [ sh:class dcterms:LinguisticSystem ;
            sh:description "Språk brukt i ressursen (dct:language)." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path dcterms:language ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/common-ap-no/id> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Kjelde for katalogposten (ekstern oppføring)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dcterms:source ],
        [ sh:class skos:Concept ;
            sh:description "Status for ressursen frå eit kontrollert vokabular (adms:status)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <http://www.w3.org/ns/adms#status> ],
        [ sh:class dcat:Resource ;
            sh:description "Ressursen katalogposten primært beskriv." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path foaf:primaryTopic ],
        [ sh:datatype rdf:langString ;
            sh:description "Fritekstbeskrivelse av ressursen (dct:description)." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:description ],
        [ sh:class dcterms:Standard ;
            sh:description "Standard ressursen er i samsvar med." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path dcterms:conformsTo ],
        [ sh:datatype xsd:date ;
            sh:description "Dato for siste endring av ressursen (dct:modified)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:modified ] ;
    sh:targetClass dcat:CatalogRecord .

dcat:DatasetSeries a sh:NodeShape ;
    rdfs:comment "Ei serie av relaterte datasett publisert separat men med felles metadata." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class foaf:Agent ;
            sh:description "Aktøren som er ansvarleg for å tilgjengeleggjere ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path dcterms:publisher ],
        [ sh:class dcat:Dataset ;
            sh:description "Siste datasett i ei datasettserie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path dcat:last ],
        [ sh:class <http://data.europa.eu/eli/ontology#LegalResource> ;
            sh:description "Lovgjeving som gjeld for ressursen." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <http://data.europa.eu/r5r/applicableLegislation> ],
        [ sh:class dcat:Dataset ;
            sh:description "Første datasett i ei datasettserie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path dcat:first ],
        [ sh:class skos:Concept ;
            sh:description "Geografisk dekningsområde (dct:spatial)." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path dcterms:spatial ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path <https://data.norge.no/linkml/common-ap-no/id> ],
        [ sh:class dcterms:PeriodOfTime ;
            sh:description "Tidsperiode ressursen dekkar." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path dcterms:temporal ],
        [ sh:datatype xsd:date ;
            sh:description "Dato for siste endring av ressursen (dct:modified)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path dcterms:modified ],
        [ sh:datatype rdf:langString ;
            sh:description "Namn/tittel på ressursen (dct:title)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:title ],
        [ sh:class dcterms:Frequency ;
            sh:description "Oppdateringsfrekvens for datasettet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path dcterms:accrualPeriodicity ],
        [ sh:datatype xsd:date ;
            sh:description "Dato ressursen vart første gong publisert (dct:issued)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path dcterms:issued ],
        [ sh:datatype rdf:langString ;
            sh:description "Fritekstbeskrivelse av ressursen (dct:description)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcterms:description ],
        [ sh:class skos:Concept ;
            sh:description "Tema frå eit kontrollert vokabular." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path dcat:theme ],
        [ sh:class <http://www.w3.org/2006/vcard/ns#Kind> ;
            sh:description "Kontaktinformasjon for hendvendelsar om ressursen." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path dcat:contactPoint ] ;
    sh:targetClass dcat:DatasetSeries .

dcat:Relationship a sh:NodeShape ;
    rdfs:comment "Ein kvalifisert relasjon mellom to ressursar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class skos:Concept ;
            sh:description "Rolle ein aktør eller ressurs har i ein relasjon." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path dcat:hadRole ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/common-ap-no/id> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Den relaterte ressursen i ein kvalifisert relasjon." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:relation ] ;
    sh:targetClass dcat:Relationship .

dcat:Resource a sh:NodeShape ;
    rdfs:comment "Basisklasse for ressursar som kan katalogiserast." ;
    sh:closed true ;
    sh:ignoredProperties ( dcat:catalog prov:wasGeneratedBy dcterms:subject dcat:service dcat:record dcterms:format dcterms:temporal <http://data.europa.eu/r5r/applicableLegislation> dcterms:hasPart dcterms:spatial dcat:themeTaxonomy <http://www.w3.org/ns/adms#status> dcat:last <http://data.europa.eu/m8g/hasCost> <http://www.w3.org/ns/adms#identifier> dcterms:description dcat:theme dcat:dataset dcat:servesDataset dcterms:license dcat:keyword dcat:endpointURL dcat:contactPoint dcterms:title dcterms:identifier dcat:landingPage dcat:first dcat:inSeries dcterms:source dcterms:language dcterms:issued dcterms:accrualPeriodicity dcterms:publisher dcat:endpointDescription foaf:page dcterms:modified prov:qualifiedAttribution dcat:version rdf:type <http://www.w3.org/ns/adms#versionNotes> dcterms:accessRights <http://data.europa.eu/r5r/availability> dcat:qualifiedRelation <http://www.w3.org/ns/adms#sample> dcterms:creator dcterms:type foaf:homepage dcat:distribution dcterms:conformsTo dcterms:relation dcterms:provenance dcterms:rights ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/common-ap-no/id> ] ;
    sh:targetClass dcat:Resource .

