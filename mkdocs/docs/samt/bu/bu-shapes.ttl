@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix samtbuskole: <https://example.no/ontology/skole#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

samtbuskole:Containerklasse a sh:NodeShape ;
    rdfs:comment "Containerklasse for alle klasser som kan inngå i datasettet." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <http://data.europa.eu/eli/ontology#LegalResource> ;
            sh:description "Gjeldande lovgiving for datasettet." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path samtbuskole:gjeldende_lovgivninger ],
        [ sh:class foaf:Agent ;
            sh:description "Organisasjonar knytt til datasettet." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path samtbuskole:organisasjoner ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Kvalitetsmålingar for datasettet." ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path samtbuskole:kvalitetsmaalinger ],
        [ sh:class <http://www.w3.org/2006/vcard/ns#Kind> ;
            sh:description "Kontaktpunkt for datasettet." ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path samtbuskole:kontaktpunkter ],
        [ sh:class samtbuskole:Fylke ;
            sh:description "Container slot for å legge tilrette for å kunne ha fleire instanser av fylke i ei datafil." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path samtbuskole:fylker ],
        [ sh:class samtbuskole:PrivatVirksomhet ;
            sh:description "Container slot for å legge tilrette for å kunne ha fleire instanser av private_virksomheter i ei datafil." ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path samtbuskole:private_virksomheter ],
        [ sh:class samtbuskole:Basisgruppe ;
            sh:description "Container slot for å legge tilrette for å kunne ha fleire instanser av basisgruppe i ei datafil." ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path samtbuskole:basisgrupper ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator (CURIE/URI)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path samtbuskole:identifikator ],
        [ sh:class samtbuskole:Rektor ;
            sh:description "Container slot for å legge tilrette for å kunne ha fleire instanser av rektor i ei datafil." ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path samtbuskole:rektorer ],
        [ sh:class samtbuskole:Elev ;
            sh:description "Container slot for å legge tilrette for å kunne ha fleire instanser av elev i ei datafil." ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path samtbuskole:elever ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Kvalitetsmerknader for datasettet." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path samtbuskole:kvalitetsmerknader ],
        [ sh:class samtbuskole:Kommune ;
            sh:description "Container slot for å legge tilrette for å kunne ha fleire instanser av kommune i ei datafil." ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path samtbuskole:kommuner ],
        [ sh:class dcat:Distribution ;
            sh:description "Distribusjonar av datasettet." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path samtbuskole:datasettdistribusjoner ],
        [ sh:class dcterms:Standard ;
            sh:description "Standardar datasettet følgjer." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path samtbuskole:standarder ],
        [ sh:class dcat:Dataset ;
            sh:description "Metadata om datasettet." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path samtbuskole:dataset_metadata ],
        [ sh:class samtbuskole:Kontaktlaerer ;
            sh:description "Container slot for å legge tilrette for å kunne ha fleire instanser av kontaktlaerer i ei datafil." ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path samtbuskole:kontaktlaerere ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Grupper knytt til datasettet." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path samtbuskole:grupper ],
        [ sh:class samtbuskole:Skole ;
            sh:description "Container slot for å legge tilrette for å kunne ha fleire instanser av skole i ei datafil." ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path samtbuskole:skoler ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Brukartilbakemeldingar for datasettet." ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path samtbuskole:brukertilbakemeldinger ],
        [ sh:class foaf:Agent ;
            sh:description "Utgjevarar av datasettet." ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path samtbuskole:utgivere ] ;
    sh:targetClass samtbuskole:Containerklasse .

samtbuskole:Person a sh:NodeShape ;
    rdfs:comment "Eit menneske individ" ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type samtbuskole:horer_til_basisgruppe samtbuskole:jobber_paa_skole samtbuskole:enhetsleder_for samtbuskole:tilknyttet_basisgruppe samtbuskole:har_saerlig_ansvar_for ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Namn på ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path samtbuskole:navn ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator (CURIE/URI)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path samtbuskole:identifikator ] ;
    sh:targetClass samtbuskole:Person .

<http://data.europa.eu/m8g/Cost> a sh:NodeShape ;
    rdfs:comment "Eit gebyr knytt til bruk av ein datatjeneste." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class skos:Concept ;
            sh:description "Valuta (cv:currency)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <http://data.europa.eu/m8g/currency> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Lenke til dokumentasjon om ressursen." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path foaf:page ],
        [ sh:datatype xsd:string ;
            sh:description "Beløp for gebyret." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <http://data.europa.eu/m8g/hasValue> ],
        [ sh:datatype rdf:langString ;
            sh:description "Fritekstbeskrivelse av ressursen (dct:description)." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/common-ap-no/id> ] ;
    sh:targetClass <http://data.europa.eu/m8g/Cost> .

dcterms:Frequency a sh:NodeShape ;
    rdfs:comment "Ein oppdateringsfrekvens." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
