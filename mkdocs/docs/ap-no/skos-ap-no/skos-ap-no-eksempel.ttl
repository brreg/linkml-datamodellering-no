@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix ns1: <https://data.norge.no/linkml/skos-ap-no-fixture/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosno: <https://data.norge.no/vocabulary/skosno#> .

<https://example.org/samlingar/dcat-omgrep> a skos:Collection ;
    dct:description "Omgrep frå DCAT-AP-NO-vokabularet."^^rdf:langString ;
    dct:identifier "dcat-omgrep-2024" ;
    dct:publisher <https://example.org/org/digdir> ;
    dct:title "DCAT-omgrep"^^rdf:langString ;
    skos:member <https://example.org/omgrep/dataressurs>,
        <https://example.org/omgrep/datasett> ;
    dcat:contactPoint <https://example.org/kontakt/digdir> .

<https://example.org/relasjonar/datasett-dataressurs> a skosno:GenericConceptRelation ;
    dct:description "grad av strukturering og tilgjengeleggjering"^^rdf:langString ;
    skosno:hasGenericConcept <https://example.org/omgrep/dataressurs> ;
    skosno:hasSpecificConcept <https://example.org/omgrep/datasett> .

<https://example.org/omgrep/dataressurs> a skos:Concept ;
    dct:identifier "https://example.org/omgrep/dataressurs" ;
    dct:publisher <https://example.org/org/digdir> ;
    skos:definition "ei eining med data"^^rdf:langString ;
    skos:prefLabel "dataressurs"^^rdf:langString ;
    dcat:contactPoint <https://example.org/kontakt/digdir> .

<https://example.org/omgrep/datasett> a skos:Concept ;
    dct:creator <https://example.org/org/digdir> ;
    dct:identifier "https://example.org/omgrep/datasett" ;
    dct:publisher <https://example.org/org/digdir> ;
    skos:altLabel "data"^^rdf:langString ;
    skos:definition "ei samling av data, tilgjengeleg eller forvalta som ei eining"^^rdf:langString ;
    skos:prefLabel "datasett"^^rdf:langString ;
    skos:scopeNote "Eit datasett kan ha éin eller fleire distribusjonar."^^rdf:langString ;
    dcat:contactPoint <https://example.org/kontakt/digdir> ;
    skosno:hasGenericConceptRelation <https://example.org/relasjonar/datasett-dataressurs> .

[] a ns1:Container ;
    ns1:begrep <https://example.org/omgrep/dataressurs>,
        <https://example.org/omgrep/datasett> ;
    ns1:generiskeRelasjonar <https://example.org/relasjonar/datasett-dataressurs> ;
    ns1:samlingar <https://example.org/samlingar/dcat-omgrep> .

