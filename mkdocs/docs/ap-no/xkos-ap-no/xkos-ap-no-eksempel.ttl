@prefix dct: <http://purl.org/dc/terms/> .
@prefix ns1: <https://data.norge.no/linkml/xkos-ap-no-fixture/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xkos: <http://rdf-vocabulary.ddialliance.org/xkos#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/kategori/nace2-01> a skos:Concept ;
    xkos:belongsTo <https://example.org/nivaa/nace2-avdelingar> ;
    skos:broader <https://example.org/kategori/nace2-A> ;
    skos:inScheme <https://example.org/klassifikasjon/nace2> ;
    skos:prefLabel "Dyrking av vekstar, husdyrhald, jakt og tilhøyrande tenester"^^rdf:langString .

<https://example.org/kategori/nace2-05> a skos:Concept ;
    xkos:belongsTo <https://example.org/nivaa/nace2-avdelingar> ;
    skos:broader <https://example.org/kategori/nace2-B> ;
    skos:inScheme <https://example.org/klassifikasjon/nace2> ;
    skos:prefLabel "Bryting av steinkol"^^rdf:langString .

<https://example.org/kategori/nace2-A> a skos:Concept ;
    xkos:belongsTo <https://example.org/nivaa/nace2-seksjonar> ;
    skos:inScheme <https://example.org/klassifikasjon/nace2> ;
    skos:narrower <https://example.org/kategori/nace2-01> ;
    skos:prefLabel "Jordbruk, skogbruk og fiske"^^rdf:langString .

<https://example.org/kategori/nace2-B> a skos:Concept ;
    xkos:belongsTo <https://example.org/nivaa/nace2-seksjonar> ;
    skos:inScheme <https://example.org/klassifikasjon/nace2> ;
    skos:narrower <https://example.org/kategori/nace2-05> ;
    skos:prefLabel "Bergverksdrift og utvinning"^^rdf:langString .

<https://example.org/nivaa/nace2-avdelingar> a xkos:ClassificationLevel ;
    dct:title "Avdelingar"^^rdf:langString ;
    xkos:depth "2"^^xsd:nonNegativeInteger ;
    skos:member <https://example.org/kategori/nace2-01>,
        <https://example.org/kategori/nace2-05> .

<https://example.org/nivaa/nace2-seksjonar> a xkos:ClassificationLevel ;
    dct:title "Seksjonar"^^rdf:langString ;
    xkos:depth "1"^^xsd:nonNegativeInteger ;
    skos:member <https://example.org/kategori/nace2-A>,
        <https://example.org/kategori/nace2-B> .

<https://example.org/klassifikasjon/nace2> a skos:ConceptScheme ;
    dct:description "Nomenklatur for økonomiske aktivitetar (NACE Rev. 2)."^^rdf:langString ;
    dct:identifier "NACE-Rev2" ;
    dct:publisher <https://example.org/org/ssb> ;
    dct:subject <https://example.org/tema/okonomi> ;
    dct:title "NACE Rev. 2"^^rdf:langString ;
    xkos:levels <https://example.org/nivaa/nace2-seksjonar> ;
    xkos:numberOfLevels "2"^^xsd:nonNegativeInteger .

[] a ns1:Container ;
    ns1:kategoriar <https://example.org/kategori/nace2-01>,
        <https://example.org/kategori/nace2-05>,
        <https://example.org/kategori/nace2-A>,
        <https://example.org/kategori/nace2-B> ;
    ns1:klassifikasjonar <https://example.org/klassifikasjon/nace2> ;
    ns1:klassifikasjonsnivaar <https://example.org/nivaa/nace2-avdelingar>,
        <https://example.org/nivaa/nace2-seksjonar> .

