@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix cv: <http://data.europa.eu/m8g/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix eli: <http://data.europa.eu/eli/ontology#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix spdx: <http://spdx.org/rdf/terms#> .
@prefix time1: <http://www.w3.org/6006/time#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://data.norge.no/linkml/common-ap-no/anbefalt_term> a owl:DatatypeProperty ;
    rdfs:label "anbefalt_term" ;
    rdfs:range rdf:langString ;
    skos:definition "Føretrukke term/namn for ressursen (skos:prefLabel)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/har_merknad> a owl:DatatypeProperty ;
    rdfs:label "har_merknad" ;
    rdfs:range rdf:langString ;
    skos:definition "Fritekstmerknad (rdfs:comment)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/har_versjonsnummer> a owl:DatatypeProperty ;
    rdfs:label "har_versjonsnummer" ;
    rdfs:range xsd:string ;
    skos:definition "Versjonsnummer for ressursen (owl:versionInfo)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no.owl.ttl> a owl:Ontology ;
    rdfs:label "dcat-ap-no" ;
    dct:title "DCAT-AP-NO" ;
    pav:version "2.0" ;
    skos:definition "Norsk applikasjonsprofil av DCAT-AP, modellert i LinkML med lenking framfor inlining. Basert på https://informasjonsforvaltning.github.io/dcat-ap-no/" .

<https://data.norge.no/linkml/dcat-ap-no/referanse> a owl:DatatypeProperty ;
    rdfs:label "referanse" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Referanse til ekstern ressurs." ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/tittel_literal> a owl:DatatypeProperty ;
    rdfs:label "tittel_literal" ;
    rdfs:range xsd:string ;
    skos:definition "Namn/tittel utan språktag." ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

xsd:duration a rdfs:Datatype .

xsd:gYear a rdfs:Datatype .

xsd:nonNegativeInteger a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:integer ;
            owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] .

<https://data.norge.no/linkml/common-ap-no/Begrepssamling> a owl:Class ;
    rdfs:label "Begrepssamling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ei SKOS-omgrepssamling (temavokabular)." ;
    skos:exactMatch skos:ConceptScheme ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/heimeside> a owl:DatatypeProperty ;
    rdfs:label "heimeside" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Heimeside for ressursen eller organisasjonen (foaf:homepage)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/Datasettserie> a owl:Class ;
    rdfs:label "Datasettserie" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Kontaktopplysning> ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/kontaktpunkt> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/forste> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/tidsrom> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/common-ap-no/Konsept> ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/dekningsomrade> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/utgivelsesdato> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Datasett> ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/forste> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/frekvens> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/dekningsomrade> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/RegulativRessurs> ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/gjeldende_lovgivning> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/endringsdato> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/kontaktpunkt> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/siste> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Datasett> ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/siste> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Frekvens> ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/frekvens> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/utgiver> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/utgivelsesdato> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/endringsdato> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/gjeldende_lovgivning> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/frekvens> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/endringsdato> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Tidsrom> ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/tidsrom> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/common-ap-no/Konsept> ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/tema> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/forste> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/siste> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/utgivelsesdato> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Aktor> ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/utgiver> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/tema> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/utgiver> ],
        <https://data.norge.no/linkml/dcat-ap-no/KatalogisertRessurs> ;
    skos:definition "Ei serie av relaterte datasett publisert separat men med felles metadata." ;
    skos:exactMatch dcat:DatasetSeries ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/Frekvens> a owl:Class ;
    rdfs:label "Frekvens" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ein oppdateringsfrekvens." ;
    skos:exactMatch dct:Frequency ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/Gebyr> a owl:Class ;
    rdfs:label "Gebyr" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/valuta> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/common-ap-no/Konsept> ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/valuta> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/belop> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/valuta> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/belop> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/dokumentasjon> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/belop> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/dokumentasjon> ] ;
    skos:definition "Eit gebyr knytt til bruk av ein datatjeneste." ;
    skos:exactMatch cv:Cost ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/Identifikator> a owl:Class ;
    rdfs:label "Identifikator" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/notasjon> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/notasjon> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/notasjon> ] ;
    skos:definition "Ein alternativ identifikator for ein ressurs." ;
    skos:exactMatch adms:Identifier ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/Katalogpost> a owl:Class ;
    rdfs:label "Katalogpost" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/kilde_post> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/status> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/endringsdato> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/utgivelsesdato> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/sprak> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/endringsdato> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/common-ap-no/Spraak> ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/sprak> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/common-ap-no/Konsept> ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/status> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/utgivelsesdato> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/primaertema> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Standard> ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/i_samsvar_med> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/kilde_post> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/kilde_post> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/status> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/primaertema> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/KatalogisertRessurs> ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/primaertema> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/utgivelsesdato> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/i_samsvar_med> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/endringsdato> ] ;
    skos:definition "Ein katalogpost som beskriv ein ressurs i katalogen." ;
    skos:exactMatch dcat:CatalogRecord ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/OdrlPolicy> a owl:Class ;
    rdfs:label "OdrlPolicy" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ein ODRL-policy." ;
    skos:exactMatch odrl:Policy ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/ProvAktivitet> a owl:Class ;
    rdfs:label "ProvAktivitet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ein PROV-aktivitet." ;
    skos:exactMatch prov:Activity ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/ProvAttributering> a owl:Class ;
    rdfs:label "ProvAttributering" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ein kvalifisert PROV-attributering." ;
    skos:exactMatch prov:Attribution ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/ProvenanceStatement> a owl:Class ;
    rdfs:label "ProvenanceStatement" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ein provenienserklæring." ;
    skos:exactMatch dct:ProvenanceStatement ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/Relasjon> a owl:Class ;
    rdfs:label "Relasjon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/har_rolle> ],
        [ a owl:Restriction ;
