            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path dct:issued ],
        [ sh:class dcat:CatalogRecord ;
            sh:description "Katalogpostar i katalogen." ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path dcat:record ],
        [ sh:class dcat:Catalog ;
            sh:description "Katalog som er ein del av denne katalogen." ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path dcat:catalog ],
        [ sh:class vcard:Kind ;
