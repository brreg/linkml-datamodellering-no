    sh:targetClass dcat:Relationship .

dcat:Resource a sh:NodeShape ;
    rdfs:comment "Basisklasse for ressursar som kan katalogiserast." ;
    sh:closed true ;
    sh:ignoredProperties ( dct:type cv:hasCost dcat:first dct:title prov:wasGeneratedBy dct:identifier dcat:service dct:publisher dct:accrualPeriodicity dct:rights adms:identifier dct:provenance dcat:inSeries dcat:keyword dcat:servesDataset dcatap:applicableLegislation dct:temporal rdf:type dct:issued dcat:last dct:source dcat:version dcat:theme dcatap:availability dcat:endpointURL dcat:endpointDescription dcat:distribution adms:versionNotes dct:spatial dcat:dataset foaf:homepage dct:relation dcat:record dct:accessRights dct:description dct:hasPart dct:modified prov:qualifiedAttribution dcat:contactPoint dcat:landingPage dct:creator dct:format dct:license dct:subject dcat:themeTaxonomy foaf:page dct:language adms:status adms:sample dcat:catalog dct:conformsTo dcat:qualifiedRelation ) ;
