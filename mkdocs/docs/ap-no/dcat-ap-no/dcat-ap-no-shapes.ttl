@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix cv: <http://data.europa.eu/m8g/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcatap: <http://data.europa.eu/r5r/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix eli: <http://data.europa.eu/eli/ontology#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix odrs: <http://schema.theodi.org/odrs#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix spdx: <http://spdx.org/rdf/terms#> .
@prefix time1: <http://www.w3.org/6006/time#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cv:Cost a sh:NodeShape ;
    rdfs:comment "Eit gebyr knytt til bruk av ein datatjeneste." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Beløp for gebyret." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path cv:hasValue ],
        [ sh:datatype rdf:langString ;
            sh:description "Fritekstbeskrivelse av ressursen (dct:description)." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dct:description ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Lenke til dokumentasjon om ressursen." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path foaf:page ],
        [ sh:class skos:Concept ;
            sh:description "Valuta (cv:currency)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path cv:currency ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/common-ap-no/id> ] ;
    sh:targetClass cv:Cost .

dct:Frequency a sh:NodeShape ;
    rdfs:comment "Ein oppdateringsfrekvens." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
