        [ sh:class dcat:Catalog ;
            sh:description "Delkatalog inkludert i denne katalogen." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path dct:hasPart ],
        [ sh:class foaf:Agent ;
            sh:description "Aktøren som er ansvarleg for å tilgjengeleggjere ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
