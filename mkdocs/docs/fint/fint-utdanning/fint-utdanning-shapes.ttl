utd:FagvurderingAbstrakt a sh:NodeShape ;
    rdfs:comment "Abstrakt basisklasse for fagvurderingar." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type <https://schema.fintlabs.no/utdanning/:eksamensgruppe> <https://schema.fintlabs.no/utdanning/:karakterhistorie> <https://schema.fintlabs.no/utdanning/:elevvurdering> ) ;
    sh:property [ sh:class utd:Skoleaar ;
            sh:description "Skoleåret vurderinga tilhøyrer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path utd:skoleaar ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:datatype xsd:string ;
            sh:description "Kommentar til vurderinga." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path utd:kommentar ],
        [ sh:class utd:Karakterverdi ;
            sh:description "Karakterverdien gjeve i vurderinga." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path utd:karakter ],
        [ sh:class utd:Fag ;
            sh:description "Faget vurderinga gjeld." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path utd:fag ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Dato og tidspunkt for vurderinga." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path utd:vurderingsdato ] ;
    sh:targetClass utd:FagvurderingAbstrakt .

utd:Gruppe a sh:NodeShape ;
