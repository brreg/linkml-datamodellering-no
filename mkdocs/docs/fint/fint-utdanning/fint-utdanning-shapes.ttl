            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path utd:beskrivelse ] ;
    sh:targetClass utd:Gruppe .

utd:Gruppemedlemskap a sh:NodeShape ;
    rdfs:comment "Abstrakt basisklasse for gruppemedlemskapar i utdanning." ;
    sh:closed false ;
    sh:ignoredProperties ( utd:delegert <https://schema.fintlabs.no/utdanning/:kontaktlaerergruppe> <https://schema.fintlabs.no/utdanning/:elevforhold> <https://schema.fintlabs.no/utdanning/:betalingsstatus> <https://schema.fintlabs.no/utdanning/:faggruppe> <https://schema.fintlabs.no/utdanning/:klasse> utd:foretrukketSensor <https://schema.fintlabs.no/utdanning/:varsel> <https://schema.fintlabs.no/utdanning/:programomrade> <https://schema.fintlabs.no/utdanning/:eksamensgruppe> utd:fagmerknad utd:nus <https://schema.fintlabs.no/utdanning/:fagstatus> utd:kandidatnummer <https://schema.fintlabs.no/utdanning/:undervisningsgruppe> utd:delegertTil rdf:type utd:foretrukketSkole utd:persongruppe ) ;
