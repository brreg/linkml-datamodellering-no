<https://schema.fintlabs.no/ressurs/:navn> a owl:DatatypeProperty ;
    rdfs:label "navn" ;
    skos:definition "Hovudnamn for omgrepet.",
        "Namnet slik det framkjem i fagsystemet.",
        "Namnet slik det framkjem i fagsystemet/datakatalogen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-ressurs> .

<https://schema.fintlabs.no/:id> a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URI-identifikator for ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .


