<https://schema.fintlabs.no/okonomi/:Fakturamottaker> a owl:Class ;
    rdfs:label "Fakturamottaker" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/okonomi/:person> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/okonomi/:person> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/okonomi/:person> ] ;
    skos:definition "Aktør som skal betale faktura (kompleks datatype)." ;
    skos:exactMatch okn:Fakturamottaker ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/:Aktoer> a owl:Class ;
    rdfs:label "Aktoer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Kontaktinformasjon> ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ],
        [ a owl:Restriction ;
