            owl:onProperty <https://schema.fintlabs.no/okonomi/:bilagsnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/okonomi/:bilagsdato> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/okonomi/:referanse> ] ;
    skos:definition "Dokumentasjon til ein transaksjon (kompleks datatype)." ;
    skos:exactMatch okn:Bilag ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:Fakturalinje> a owl:Class ;
    rdfs:label "Fakturalinje" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/okonomi/:antall> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/okonomi/:antall> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/okonomi/:pris> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/okonomi/:pris> ],
        [ a owl:Restriction ;
