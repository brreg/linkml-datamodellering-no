    skos:definition "Angir gyldighetsperioden for eit omgrep/kode.",
        "Perioden ein gjeven identifikator er gyldig." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:kontaktinformasjon> a owl:ObjectProperty ;
    rdfs:label "kontaktinformasjon" ;
    skos:definition "Den føretrekte måten å kome i kontakt med ein aktør.",
        "Kontaktinformasjon for kontaktpersonen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/okonomi/:fakturautsteder> a owl:ObjectProperty ;
    rdfs:label "fakturautsteder" ;
    skos:definition "Fakturautstedar for varen.",
        "Utstedar av faktura og mottakar av betaling." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:forfallsdato> a owl:DatatypeProperty ;
    rdfs:label "forfallsdato" ;
    skos:definition "Dato transaksjonen forfell.",
        "Frist for betaling." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:kontering> a owl:ObjectProperty ;
    rdfs:label "kontering" ;
    skos:definition "Kontodimensjonar for posteringa.",
        "Varens kontering i økonomisystemet." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:mottaker> a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "mottaker" ;
    skos:definition "Mottakar som skal betale faktura.",
        "Namn på mottakar." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:person> a owl:DatatypeProperty ;
    rdfs:label "person" ;
    skos:definition "Referanse til Person (Administrasjon) som er leverandør.",
        "Referanse til Person (Administrasjon) som skal betale faktura." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:pris> a owl:DatatypeProperty ;
    rdfs:label "pris" ;
    skos:definition "Pris per eining levert, i øre.",
        "Varens pris per eining i vareregisteret, i øre." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:fakturagrunnlag> a owl:ObjectProperty ;
    rdfs:label "fakturagrunnlag" ;
    skos:definition "Alle fakturagrunnlag for fakturutstedaren.",
        "Grunnlag for fakturering." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:belop> a owl:DatatypeProperty ;
    rdfs:label "belop" ;
    skos:definition "Beløp mottakar skal betale, i øre (beløp).",
        "Posteringsbeløp med to desimalar (beløp).",
        "Transaksjonsbeløp med to desimalar (beløp)." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:gyldighetsperiode> a owl:ObjectProperty ;
    rdfs:label "gyldighetsperiode" ;
    skos:definition "Angir gyldighetsperioden for omgrepet/koden." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:kode> a owl:DatatypeProperty ;
    rdfs:label "kode" ;
    skos:definition "Valutakode (t.d. NOK, EUR, USD).",
        "Verdi som identifiserer omgrepet." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:passiv> a owl:DatatypeProperty ;
    rdfs:label "passiv" ;
    skos:definition "Angir at koden er passiv og ikkje kan veljast." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/:Identifikator> a owl:Class ;
    rdfs:label "Identifikator" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:identifikatorverdi> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:identifikatorverdi> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:identifikatorverdi> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Periode> ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ] ;
    skos:definition "Unik identifikasjon til eit objekt." ;
    skos:exactMatch fint:Identifikator ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:navn> a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "navn" ;
    skos:definition "Hovudnamn for omgrepet.",
        "Namn på kontaktpersonen.",
        "Namn på personen.",
        "Namn på valuta." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/okonomi/:navn> a owl:DatatypeProperty ;
    rdfs:label "navn" ;
    skos:definition "Hovudnamn for omgrepet.",
        "Juridisk namn på fakturutstedar.",
        "Namn på leverandørgruppen.",
        "Namn på valutaen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/:id> a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URI-identifikator for ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .


