    skos:definition "Leverandør knytt til transaksjonen (leverandor).",
        "Leverandørar i leverandørgruppen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-okonomi> .

<https://schema.fintlabs.no/okonomi/:vare> a owl:ObjectProperty ;
