            owl:onProperty <https://schema.fintlabs.no/administrasjon/:anvist> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:beskrivelse> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:kontostreng> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:konterer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:anviser> ],
        [ a owl:Restriction ;
