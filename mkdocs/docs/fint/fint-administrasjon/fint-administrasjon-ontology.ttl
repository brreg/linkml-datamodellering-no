        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:antall> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:lonsart> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:antall> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/administrasjon/:Arbeidsforhold> ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:arbeidsforhold> ],
        [ a owl:Restriction ;
