            owl:onProperty <https://schema.fintlabs.no/administrasjon/:belop> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:belop> ],
        <https://schema.fintlabs.no/administrasjon/:Lonn> ;
    skos:definition "Informasjon om variabel lønn." ;
    skos:exactMatch adm:Variabellonn ;
    skos:inScheme <https://data.norge.no/linkml/fint-administrasjon> .

