    skos:inScheme <https://data.norge.no/linkml/fint-administrasjon> .

<https://schema.fintlabs.no/administrasjon/:Fravaerstype> a owl:Class ;
    rdfs:label "Fravaerstype" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:lonsart> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:lonsart> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/administrasjon/:Lonsart> ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:lonsart> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:overfores> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:overfores> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:overfores> ],
        <https://schema.fintlabs.no/:Begrep> ;
    skos:definition "Type fråvær." ;
    skos:exactMatch adm:Fravaerstype ;
    skos:inScheme <https://data.norge.no/linkml/fint-administrasjon> .

<https://schema.fintlabs.no/administrasjon/:Organisasjonstype> a owl:Class ;
