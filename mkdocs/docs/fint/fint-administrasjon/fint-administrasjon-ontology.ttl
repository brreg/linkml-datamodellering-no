            owl:onProperty <https://schema.fintlabs.no/administrasjon/:stillingskode> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:arbeidslokasjon> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/administrasjon/:Lopenummer> ;
            owl:onProperty <https://schema.fintlabs.no/administrasjon/:lopenummer> ] ;
    skos:definition "Eit avtaleforhold mellom personalressurs og arbeidsgjevar." ;
    skos:exactMatch adm:Arbeidsforhold ;
    skos:inScheme <https://data.norge.no/linkml/fint-administrasjon> .

<https://schema.fintlabs.no/administrasjon/:aktivitet> a owl:ObjectProperty ;
