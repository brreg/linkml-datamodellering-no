        [ sh:class adm:Fasttillegg ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:fasttillegg> ],
        [ sh:class adm:Lopenummer ;
            sh:nodeKind sh:IRI ;
            sh:order 31 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:lopenummer> ] ;
    sh:targetClass <https://schema.fintlabs.no/administrasjon/:AdministrasjonContainer> .

adm:Lonn a sh:NodeShape ;
    rdfs:comment "Informasjon om lønn for eit arbeidsforhold (abstrakt base)." ;
    sh:closed false ;
    sh:ignoredProperties ( <https://schema.fintlabs.no/administrasjon/:prosent> <https://schema.fintlabs.no/administrasjon/:belop> adm:antall <https://schema.fintlabs.no/administrasjon/:lonsart> <https://schema.fintlabs.no/administrasjon/:arbeidsforhold> rdf:type ) ;
    sh:property [ sh:class adm:Personalressurs ;
            sh:description "Personalressurs som har attestert lønsmeldinga etter fullmakt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path adm:attestant ],
        [ sh:class adm:Kontostreng ;
            sh:description "Kontering av lønn." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path adm:kontostreng ],
        [ sh:class fint:Periode ;
            sh:description "Periode lønn vert utbetalt." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path adm:periode ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:class adm:Personalressurs ;
            sh:description "Personalressurs som har anvist lønsmeldinga etter fullmakt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path adm:anviser ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Tidspunkt då lønn vart attestert." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path adm:attestert ],
        [ sh:class fint:Identifikator ;
            sh:description "Kjeldesystemets unike identifikator for lønn." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path adm:kildesystemId ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Tidspunkt då lønn vart kontert." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path adm:kontert ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Tidspunkt då lønn vart anvist." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path adm:anvist ],
        [ sh:datatype xsd:string ;
            sh:description "Beskriving av lønn til føring på lønnslipp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path adm:beskrivelse ],
        [ sh:class fint:Periode ;
            sh:description "Periode der lønn vart opptent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path adm:opptjent ],
        [ sh:class adm:Personalressurs ;
            sh:description "Personalressurs som har kontert lønsmeldinga etter fullmakt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path adm:konterer ] ;
    sh:targetClass adm:Lonn .

adm:Arbeidslokasjon a sh:NodeShape ;
    rdfs:comment "Fysisk lokasjon der ein tilsett har sitt arbeidsstad." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Namn som beskriv ein arbeidslokasjon." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path adm:lokasjonsnavn ],
        [ sh:datatype xsd:string ;
            sh:description "Namn på eining registrert i Einingsregisteret." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path adm:organisasjonsnavn ],
        [ sh:class fint:Identifikator ;
            sh:description "Niisifra nummer som eintydleg identifiserer einingar i Einingsregisteret." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path adm:organisasjonsnummer ],
        [ sh:class adm:Arbeidsforhold ;
            sh:description "Arbeidsforhold knytt til arbeidslokasjonen." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path adm:arbeidsforhold ],
        [ sh:class fint:Kontaktinformasjon ;
            sh:description "Kontaktinformasjon til arbeidslokasjonen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path adm:kontaktinformasjon ],
        [ sh:class fint:Adresse ;
            sh:description "Postadresse til arbeidslokasjonen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path adm:postadresse ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:class fint:Identifikator ;
            sh:description "Kode som identifiserer ein arbeidslokasjon." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path adm:lokasjonskode ],
        [ sh:class fint:Adresse ;
            sh:description "Besøksadresse til organisasjonseininga." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path adm:forretningsadresse ] ;
    sh:targetClass adm:Arbeidslokasjon .

adm:Fastlonn a sh:NodeShape ;
