adm:Fravaersgrunn a sh:NodeShape ;
    rdfs:comment "Grunn til fråvær." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:class fint:Periode ;
            sh:description "Angir gyldighetsperioden for eit omgrep/kode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path fint:gyldighetsperiode ],
        [ sh:datatype xsd:boolean ;
            sh:description "Angir at koden er passiv og ikkje kan veljast." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path fint:passiv ],
        [ sh:datatype xsd:string ;
            sh:description "Hovudnamn for omgrepet." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path fint:navn ],
        [ sh:datatype xsd:string ;
            sh:description "Verdi som identifiserer omgrepet." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path fint:kode ] ;
    sh:targetClass adm:Fravaersgrunn .

adm:Fravaerstype a sh:NodeShape ;
    rdfs:comment "Type fråvær." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Angir at koden er passiv og ikkje kan veljast." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path fint:passiv ],
        [ sh:datatype xsd:string ;
            sh:description "Verdi som identifiserer omgrepet." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
