            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path adm:konterer ],
        [ sh:class adm:Lonsart ;
            sh:description "Lønnsart for fastlønn." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path adm:lonsart ],
        [ sh:class adm:Arbeidsforhold ;
            sh:description "Arbeidsforhold fastlønna gjeld for." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path adm:arbeidsforhold ],
        [ sh:class adm:Kontostreng ;
            sh:description "Kontering av lønn." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path adm:kontostreng ],
        [ sh:class fint:Periode ;
            sh:description "Periode der lønn vart opptent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path adm:opptjent ],
        [ sh:datatype xsd:integer ;
            sh:description "Andel av lønnsprosent som vert beslaglagt." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path adm:prosent ],
        [ sh:datatype xsd:string ;
            sh:description "Beskriving av lønn til føring på lønnslipp." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
