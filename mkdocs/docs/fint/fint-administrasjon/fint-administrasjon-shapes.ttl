        [ sh:class adm:Rolle ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:rollar> ],
        [ sh:class adm:Kontrakt ;
            sh:nodeKind sh:IRI ;
            sh:order 29 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:kontrakter> ],
        [ sh:class adm:Organisasjonselement ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:organisasjonselement> ],
        [ sh:class fint:Kontaktperson ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:kontaktpersonar> ],
        [ sh:class adm:Art ;
            sh:nodeKind sh:IRI ;
            sh:order 22 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:artar> ],
        [ sh:class adm:Prosjekt ;
            sh:nodeKind sh:IRI ;
            sh:order 35 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:prosjekt> ],
        [ sh:class fint:Fylke ;
