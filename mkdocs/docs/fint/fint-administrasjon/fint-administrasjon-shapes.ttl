@prefix adm: <https://schema.fintlabs.no/administrasjon/> .
@prefix fint: <https://schema.fintlabs.no/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://schema.fintlabs.no/administrasjon/:AdministrasjonContainer> a sh:NodeShape ;
    rdfs:comment "Rotcontainer for FINT Administrasjon-instansar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class adm:Arbeidsforhold ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:arbeidsforhold> ],
        [ sh:class adm:Fravaer ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:fravaer> ],
        [ sh:class fint:Kommune ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:kommunar> ],
        [ sh:class adm:Ansvar ;
            sh:nodeKind sh:IRI ;
            sh:order 21 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:ansvar> ],
        [ sh:class adm:Arbeidsforholdstype ;
            sh:nodeKind sh:IRI ;
            sh:order 23 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:arbeidsforholdstypar> ],
        [ sh:class adm:Aktivitet ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:aktivitetar> ],
        [ sh:class adm:Prosjektart ;
            sh:nodeKind sh:IRI ;
            sh:order 36 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:prosjektartar> ],
        [ sh:class adm:Ramme ;
            sh:nodeKind sh:IRI ;
            sh:order 37 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:rammer> ],
        [ sh:class adm:Stillingskode ;
            sh:nodeKind sh:IRI ;
            sh:order 38 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:stillingskoder> ],
        [ sh:class adm:Fullmakt ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:fullmakter> ],
        [ sh:class fint:Spraak ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:spraak> ],
        [ sh:class adm:Objekt ;
            sh:nodeKind sh:IRI ;
            sh:order 32 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:objekt> ],
        [ sh:class adm:Arbeidslokasjon ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:arbeidslokasjoner> ],
        [ sh:class adm:Organisasjonstype ;
            sh:nodeKind sh:IRI ;
            sh:order 33 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:organisasjonstypar> ],
        [ sh:class adm:Diverse ;
            sh:nodeKind sh:IRI ;
            sh:order 24 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:diverse> ],
        [ sh:class adm:Fravaersgrunn ;
            sh:nodeKind sh:IRI ;
            sh:order 26 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:fravaersgrunnar> ],
        [ sh:class fint:Virksomhet ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:virksomhetar> ],
        [ sh:class fint:Person ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:personar> ],
        [ sh:class adm:Fravaerstype ;
            sh:nodeKind sh:IRI ;
            sh:order 27 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:fravaerstypar> ],
        [ sh:class adm:Lonsart ;
            sh:nodeKind sh:IRI ;
            sh:order 30 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:lonsartar> ],
        [ sh:class fint:Kjonn ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:kjonn> ],
        [ sh:class adm:Uketimetall ;
            sh:nodeKind sh:IRI ;
            sh:order 39 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:uketimetall> ],
        [ sh:class adm:Funksjon ;
            sh:nodeKind sh:IRI ;
            sh:order 28 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:funksjonar> ],
        [ sh:class adm:Personalressurskategori ;
            sh:nodeKind sh:IRI ;
            sh:order 34 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:personalressurskategoriar> ],
        [ sh:class adm:Personalressurs ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:personalressursar> ],
        [ sh:class adm:Anlegg ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:anlegg> ],
        [ sh:class adm:Formaal ;
            sh:nodeKind sh:IRI ;
            sh:order 25 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:formaal> ],
        [ sh:class fint:Landkode ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:landkodar> ],
        [ sh:class fint:Valuta ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path <https://schema.fintlabs.no/administrasjon/:valuta> ],
        [ sh:class adm:Fastlonn ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
