            sh:path adm:periode ],
        [ sh:datatype xsd:integer ;
            sh:description "Beløp i øre." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
