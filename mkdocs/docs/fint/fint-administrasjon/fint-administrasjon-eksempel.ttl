@prefix adm: <https://schema.fintlabs.no/administrasjon/> .
@prefix fint: <https://schema.fintlabs.no/> .
@prefix ns1: <https://schema.fintlabs.no/administrasjon/:> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.no/fint/arbeidsforhold/af-p12345-1> a adm:Arbeidsforhold ;
    adm:aarslonn 650000 ;
    adm:ansettelsesprosent 100 ;
    adm:arbeidssted <https://example.no/fint/organisasjonselement/it-avdeling> ;
    adm:gyldighetsperiode [ a fint:Periode ;
            fint:start "2020-01-15T00:00:00+00:00"^^xsd:dateTime ] ;
    adm:hovedstilling true ;
    adm:lonnsprosent 100 ;
    adm:personalressurs <https://example.no/fint/personalressurs/p12345> ;
    adm:stillingskode <https://example.no/fint/stillingskode/raadgiver> ;
    adm:stillingsnummer "1001" ;
    adm:stillingstittel "Rådgiver IKT" ;
    adm:tilstedeprosent 100 .

<https://example.no/fint/arbeidsforhold/af-p23456-1> a adm:Arbeidsforhold ;
    adm:aarslonn 850000 ;
    adm:ansettelsesprosent 100 ;
    adm:arbeidssted <https://example.no/fint/organisasjonselement/it-avdeling> ;
    adm:gyldighetsperiode [ a fint:Periode ;
            fint:start "2018-08-01T00:00:00+00:00"^^xsd:dateTime ] ;
    adm:hovedstilling true ;
    adm:lonnsprosent 100 ;
    adm:personalressurs <https://example.no/fint/personalressurs/p23456> ;
    adm:stillingskode <https://example.no/fint/stillingskode/overingenir> ;
    adm:stillingsnummer "1000" ;
    adm:stillingstittel "IKT-sjef" ;
    adm:tilstedeprosent 100 .

<https://example.no/fint/person/kari-olsen> a fint:Person ;
    fint:fodselsdato "1978-04-23"^^xsd:date ;
    fint:fodselsnummer [ a fint:Identifikator ;
            fint:identifikatorverdi "23047823456" ] ;
    fint:personNavn [ a fint:Personnavn ;
            fint:etternavn "Olsen" ;
            fint:fornavn "Kari" ;
            fint:mellomnavn "Marie" ] .

<https://example.no/fint/person/ola-nordmann> a fint:Person ;
    fint:fodselsdato "1967-05-12"^^xsd:date ;
    fint:fodselsnummer [ a fint:Identifikator ;
            fint:identifikatorverdi "12056712345" ] ;
    fint:kontaktinformasjon [ a fint:Kontaktinformasjon ;
            fint:epostadresse "ola.nordmann@kommune.no" ;
            fint:mobiltelefonnummer "97012345" ] ;
    fint:personNavn [ a fint:Personnavn ;
            fint:etternavn "Nordmann" ;
            fint:fornavn "Ola" ] .

<https://example.no/fint/personalressurs/p12345> a adm:Personalressurs ;
    adm:ansattnummer [ a fint:Identifikator ;
            fint:identifikatorverdi "P12345" ] ;
    adm:ansettelsesperiode [ a fint:Periode ;
            fint:start "2020-01-15T00:00:00+00:00"^^xsd:dateTime ] ;
    adm:jobbtittel "Rådgiver IKT" ;
    adm:kontaktinformasjon [ a fint:Kontaktinformasjon ;
            fint:epostadresse "ola.nordmann@kommune.no" ;
            fint:telefonnummer "55123456" ] ;
    adm:person <https://example.no/fint/person/ola-nordmann> ;
    adm:personalressurskategori <https://example.no/fint/personalressurskategori/fast-ansatt> .

<https://example.no/fint/personalressurs/p23456> a adm:Personalressurs ;
    adm:ansattnummer [ a fint:Identifikator ;
            fint:identifikatorverdi "P23456" ] ;
    adm:ansettelsesperiode [ a fint:Periode ;
            fint:start "2018-08-01T00:00:00+00:00"^^xsd:dateTime ] ;
    adm:jobbtittel "IKT-sjef" ;
    adm:kontaktinformasjon [ a fint:Kontaktinformasjon ;
            fint:epostadresse "kari.olsen@kommune.no" ;
            fint:telefonnummer "55123490" ] ;
    adm:person <https://example.no/fint/person/kari-olsen> ;
    adm:personalressurskategori <https://example.no/fint/personalressurskategori/fast-ansatt> .

<https://example.no/fint/stillingskode/overingenir> a adm:Stillingskode ;
    fint:kode "8530" ;
    fint:navn "Overingeniør" .

<https://example.no/fint/stillingskode/raadgiver> a adm:Stillingskode ;
    fint:kode "7451" ;
    fint:navn "Rådgiver" .

<https://example.no/fint/organisasjonselement/it-avdeling> a adm:Organisasjonselement ;
    adm:kortnavn "IKT" ;
    adm:namn "IKT-avdelingen" ;
    adm:organisasjonsId [ a fint:Identifikator ;
            fint:identifikatorverdi "110" ] ;
    adm:organisasjonsKode [ a fint:Identifikator ;
            fint:identifikatorverdi "IKT" ] ;
    adm:overordnet <https://example.no/fint/organisasjonselement/raadhuset> .

<https://example.no/fint/organisasjonselement/raadhuset> a adm:Organisasjonselement ;
    adm:kortnavn "KOM" ;
    adm:namn "Kommunedirektøren" ;
    adm:organisasjonsId [ a fint:Identifikator ;
            fint:identifikatorverdi "100" ] ;
    adm:organisasjonsKode [ a fint:Identifikator ;
            fint:identifikatorverdi "KOM" ] ;
    adm:overordnet <https://example.no/fint/organisasjonselement/raadhuset> .

<https://example.no/fint/personalressurskategori/fast-ansatt> a adm:Personalressurskategori ;
    fint:kode "F" ;
    fint:navn "Fast ansatt" .

[] a ns1:AdministrasjonContainer ;
    ns1:arbeidsforhold <https://example.no/fint/arbeidsforhold/af-p12345-1>,
        <https://example.no/fint/arbeidsforhold/af-p23456-1> ;
    ns1:organisasjonselement <https://example.no/fint/organisasjonselement/it-avdeling>,
        <https://example.no/fint/organisasjonselement/raadhuset> ;
    ns1:personalressursar <https://example.no/fint/personalressurs/p12345>,
        <https://example.no/fint/personalressurs/p23456> ;
    ns1:personalressurskategoriar <https://example.no/fint/personalressurskategori/fast-ansatt> ;
    ns1:personar <https://example.no/fint/person/kari-olsen>,
        <https://example.no/fint/person/ola-nordmann> ;
    ns1:stillingskoder <https://example.no/fint/stillingskode/overingenir>,
        <https://example.no/fint/stillingskode/raadgiver> .

