@prefix ark: <https://schema.fintlabs.no/arkiv/> .
@prefix fint: <https://schema.fintlabs.no/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://schema.fintlabs.no/arkiv/:ArkivContainer> a sh:NodeShape ;
    rdfs:comment "Rotcontainer for FINT Arkiv-instansar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ark:Sak ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path <https://schema.fintlabs.no/arkiv/:sakar> ],
        [ sh:class ark:Skjermingshjemmel ;
            sh:nodeKind sh:IRI ;
            sh:order 27 ;
            sh:path <https://schema.fintlabs.no/arkiv/:skjermingsheimlar> ],
        [ sh:class ark:Personalmappe ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <https://schema.fintlabs.no/arkiv/:personalmappe_liste> ],
        [ sh:class ark:Tilgangsgruppe ;
            sh:nodeKind sh:IRI ;
            sh:order 28 ;
            sh:path <https://schema.fintlabs.no/arkiv/:tilgangsgrupper> ],
        [ sh:class ark:SoeknadDrosjeloeyve ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path <https://schema.fintlabs.no/arkiv/:soeknadDrosjeloeyve_liste> ],
        [ sh:class ark:DispensasjonAutomatiskFredaKulturminne ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://schema.fintlabs.no/arkiv/:dispensasjonAutomatiskFredaKulturminne_liste> ],
        [ sh:class ark:Saksstatus ;
            sh:nodeKind sh:IRI ;
            sh:order 26 ;
            sh:path <https://schema.fintlabs.no/arkiv/:sakstatuskodar> ],
        [ sh:class ark:Dokumentbeskrivelse ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <https://schema.fintlabs.no/arkiv/:dokumentbeskrivelsar> ],
        [ sh:class ark:AdministrativEnhet ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <https://schema.fintlabs.no/arkiv/:administrativeEiningar> ],
        [ sh:class ark:Merknadstype ;
            sh:nodeKind sh:IRI ;
            sh:order 22 ;
            sh:path <https://schema.fintlabs.no/arkiv/:merknadstypar> ],
        [ sh:class ark:TilskuddFredaBygningPrivatEie ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path <https://schema.fintlabs.no/arkiv/:tilskuddFredaBygningPrivatEie_liste> ],
        [ sh:class ark:TilknyttetRegistreringSom ;
            sh:nodeKind sh:IRI ;
            sh:order 30 ;
            sh:path <https://schema.fintlabs.no/arkiv/:tilknyttetRegistreringSomKodar> ],
        [ sh:class ark:Klassifikasjonstype ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path <https://schema.fintlabs.no/arkiv/:klassifikasjonstypar> ],
        [ sh:class ark:Saksmappetype ;
            sh:nodeKind sh:IRI ;
            sh:order 25 ;
            sh:path <https://schema.fintlabs.no/arkiv/:saksmappetypar> ],
        [ sh:class ark:KorrespondansepartType ;
            sh:nodeKind sh:IRI ;
            sh:order 21 ;
            sh:path <https://schema.fintlabs.no/arkiv/:korrespondanseparttypar> ],
        [ sh:class ark:TilskuddFartoy ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path <https://schema.fintlabs.no/arkiv/:tilskuddFartoy_liste> ],
        [ sh:class ark:DokumentStatus ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path <https://schema.fintlabs.no/arkiv/:dokumentstatuskodar> ],
        [ sh:class ark:JournalpostType ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path <https://schema.fintlabs.no/arkiv/:journalposttypar> ],
        [ sh:class ark:Dokumentfil ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://schema.fintlabs.no/arkiv/:dokumentfiler> ],
        [ sh:class ark:Tilgang ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path <https://schema.fintlabs.no/arkiv/:tilgangar> ],
        [ sh:class ark:Arkivdel ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/arkiv/:arkivdelar> ],
        [ sh:class ark:Arkivressurs ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path <https://schema.fintlabs.no/arkiv/:arkivressursar> ],
        [ sh:class ark:JournalStatus ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path <https://schema.fintlabs.no/arkiv/:journalstatuskodar> ],
        [ sh:class ark:Autorisasjon ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <https://schema.fintlabs.no/arkiv/:autorisasjonar> ],
        [ sh:class ark:PartRolle ;
            sh:nodeKind sh:IRI ;
            sh:order 23 ;
            sh:path <https://schema.fintlabs.no/arkiv/:partRollar> ],
        [ sh:class ark:Journalpost ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <https://schema.fintlabs.no/arkiv/:journalpostar> ],
        [ sh:class ark:DokumentType ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path <https://schema.fintlabs.no/arkiv/:dokumenttypar> ],
        [ sh:class ark:Variantformat ;
            sh:nodeKind sh:IRI ;
            sh:order 31 ;
            sh:path <https://schema.fintlabs.no/arkiv/:variantformatar> ],
        [ sh:class ark:Tilgangsrestriksjon ;
            sh:nodeKind sh:IRI ;
            sh:order 29 ;
            sh:path <https://schema.fintlabs.no/arkiv/:tilgangsrestriksjonar> ],
        [ sh:class ark:Format ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path <https://schema.fintlabs.no/arkiv/:formatar> ],
        [ sh:class ark:Rolle ;
            sh:nodeKind sh:IRI ;
            sh:order 24 ;
            sh:path <https://schema.fintlabs.no/arkiv/:rollar> ],
        [ sh:class ark:Klassifikasjonssystem ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://schema.fintlabs.no/arkiv/:klassifikasjonssystem> ] ;
    sh:targetClass <https://schema.fintlabs.no/arkiv/:ArkivContainer> .

ark:Mappe a sh:NodeShape ;
    rdfs:comment "Abstrakt basisklasse for alle mappetypar. Grupperer dokument som høyrer saman." ;
    sh:closed false ;
    sh:ignoredProperties ( ark:tiltak rdf:type ark:saksdato ark:saksmappetype ark:personnavn ark:journalenhet ark:personalressurs ark:soeknadsnummer ark:administrativEnhet ark:arbeidssted ark:tilgangsgruppe ark:saksansvarlig ark:journalpost ark:sakssekvensnummer ark:kulturminneId ark:organisasjonsnummer fint:person ark:bygningsnavn ark:leder ark:matrikkelnummer ark:saksstatus ark:utlaantDato ark:kallesignal ark:saksaar ark:fartoyNavn fint:organisasjonsnavn ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Nøkkelord som skildrar innhaldet (Mappe)." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ark:noekkelord ],
        [ sh:class ark:Arkivdel ;
            sh:description "Arkivdel arkivenheten tilhøyrer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path ark:arkivdel ],
        [ sh:class fint:Identifikator ;
            sh:description "Eintydig identifikasjon av mappa innanfor arkivet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path ark:mappeId ],
        [ sh:class ark:Klasse ;
            sh:description "Klassifisering av arkivenhet." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path ark:klasse ],
        [ sh:class ark:Arkivressurs ;
            sh:description "Person som avslutta/lukka arkivenheten." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path ark:avsluttetAv ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Dato og klokkeslett når arkivenheten vart avslutta/lukka." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ark:avsluttetDato ],
        [ sh:class ark:Part ;
            sh:description "Partar til arkivenhet." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path ark:part ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Dato og klokkeslett arkivenheten vart oppretta/registrert." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ark:opprettetDato ],
        [ sh:datatype xsd:string ;
            sh:description "Beskriven namn eller omtale." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path fint:beskrivelse ],
        [ sh:datatype xsd:string ;
            sh:description "Tittel eller namn på arkivenheten." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path ark:tittel ],
        [ sh:class ark:Merknad ;
            sh:description "Merknader knytt til arkivenhet." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ark:merknad ],
        [ sh:class ark:Skjerming ;
            sh:description "Skjerming av arkivenhet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path ark:skjerming ],
        [ sh:class ark:Arkivressurs ;
            sh:description "Person som oppretta/registrerte arkivenheten." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path ark:opprettetAv ],
        [ sh:datatype xsd:string ;
            sh:description "Offentleg tittel der skjerma ord er fjerna." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path ark:offentligTittel ] ;
    sh:targetClass ark:Mappe .

ark:Registrering a sh:NodeShape ;
    rdfs:comment "Abstrakt basisklasse — arkivets primære byggeklossar." ;
    sh:closed false ;
    sh:ignoredProperties ( ark:forfallsDato ark:journalAr ark:mottattDato ark:journalenhet ark:avskrivning rdf:type ark:dokumentetsDato ark:journalstatus ark:antallVedlegg ark:offentlighetsvurdertDato ark:journalDato ark:journalposttype ark:journalPostnummer ark:sendtDato ark:journalSekvensnummer ) ;
    sh:property [ sh:class ark:Merknad ;
            sh:description "Merknader knytt til arkivenhet." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path ark:merknad ],
        [ sh:class ark:Klasse ;
            sh:description "Klassifisering av arkivenhet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path ark:klasse ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Dato og klokkeslett arkivenheten vart oppretta/registrert." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path ark:opprettetDato ],
        [ sh:class ark:Part ;
            sh:description "Partar til arkivenhet." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path ark:part ],
        [ sh:datatype xsd:string ;
            sh:description "Referanse til arkivdelen denne arkivenheten er tilknytt." ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path ark:referanseArkivDel ],
        [ sh:class ark:Arkivressurs ;
            sh:description "Person som oppretta/registrerte arkivenheten." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 21 ;
            sh:path ark:opprettetAv ],
        [ sh:class ark:Dokumentbeskrivelse ;
            sh:description "Dokumentbeskrivelsar til ei registrering." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path ark:dokumentbeskrivelse ],
        [ sh:class ark:Korrespondansepart ;
            sh:description "Mottakar eller sendar av arkivdokument." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path ark:korrespondansepart ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Dato og klokkeslett alle dokument knytt til registreringa vart arkivert." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ark:arkivertDato ],
        [ sh:class ark:Arkivressurs ;
            sh:description "Person som arkiverte arkivenheten." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path ark:arkivertAv ],
        [ sh:datatype xsd:string ;
            sh:description "Nøkkelord som skildrar innhaldet (Registrering)." ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ark:nokkelord ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:datatype xsd:string ;
            sh:description "Beskriven namn eller omtale." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path fint:beskrivelse ],
        [ sh:datatype xsd:string ;
            sh:description "Namn på person eller organisasjon som skapte dokumentet." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ark:forfatter ],
        [ sh:class ark:AdministrativEnhet ;
            sh:description "Administrativ eining som har ansvar for saksbehandlinga." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path ark:administrativEnhet ],
        [ sh:datatype xsd:string ;
            sh:description "Offentleg tittel der skjerma ord er fjerna." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ark:offentligTittel ],
        [ sh:class ark:Skjerming ;
            sh:description "Skjerming av arkivenhet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path ark:skjerming ],
        [ sh:class ark:Tilgangsgruppe ;
            sh:description "Tilgangsgruppe som har tilgang til arkivenheten." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path ark:tilgangsgruppe ],
        [ sh:class ark:Arkivressurs ;
            sh:description "Person som er saksbehandlar." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path ark:saksbehandler ],
        [ sh:class ark:Arkivdel ;
            sh:description "Arkivdel arkivenheten tilhøyrer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path ark:arkivdel ],
        [ sh:datatype xsd:string ;
            sh:description "Tittel eller namn på arkivenheten." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path ark:tittel ],
        [ sh:datatype xsd:string ;
            sh:description "Inngår i M004 journalpostID." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ark:registreringsId ] ;
    sh:targetClass ark:Registrering .

ark:Saksmappe a sh:NodeShape ;
    rdfs:comment "Abstrakt spesialisering av Mappe som svarar til ei \"sak\" i Noark." ;
    sh:closed false ;
    sh:ignoredProperties ( ark:personnavn ark:tiltak ark:personalressurs ark:soeknadsnummer ark:kulturminneId ark:organisasjonsnummer ark:matrikkelnummer fint:person rdf:type ark:kallesignal ark:fartoyNavn ark:bygningsnavn ark:leder ark:arbeidssted fint:organisasjonsnavn ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:description "Dato ein fysisk saksmappe eller journalpost vart utlånt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ark:utlaantDato ],
        [ sh:datatype xsd:string ;
            sh:description "Nøkkelord som skildrar innhaldet (Mappe)." ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path ark:noekkelord ],
        [ sh:class ark:Merknad ;
            sh:description "Merknader knytt til arkivenhet." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path ark:merknad ],
        [ sh:class ark:Arkivressurs ;
