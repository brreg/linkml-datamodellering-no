ark:AdministrativEnhet a sh:NodeShape ;
    rdfs:comment "Administrativ eining med ansvar for saksbehandling." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Hovudnamn for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
