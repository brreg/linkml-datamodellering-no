            sh:path ark:klasse ],
        [ sh:datatype xsd:string ;
            sh:description "Inngår i M003 mappeID — viser rekkjefølgja saksmappene vart oppretta." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ark:sakssekvensnummer ],
        [ sh:class ark:Skjerming ;
            sh:description "Skjerming av arkivenhet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path ark:skjerming ],
        [ sh:class ark:Arkivdel ;
