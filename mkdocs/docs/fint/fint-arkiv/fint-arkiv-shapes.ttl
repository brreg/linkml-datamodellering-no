        [ sh:class ark:Arkivressurs ;
            sh:description "Person som er saksansvarleg." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path ark:saksansvarlig ] ;
    sh:targetClass ark:Saksmappe .

ark:Avskrivning a sh:NodeShape ;
    rdfs:comment "Avskriving av ein journalpost (markering som ferdigbehandla)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Korleis journalposten er avskriven." ;
            sh:maxCount 1 ;
