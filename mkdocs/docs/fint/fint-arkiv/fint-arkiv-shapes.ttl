        [ sh:datatype xsd:string ;
            sh:description "Inngår i M003 mappeID — viser året saksmappa vart oppretta." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ark:saksaar ],
        [ sh:datatype xsd:dateTime ;
