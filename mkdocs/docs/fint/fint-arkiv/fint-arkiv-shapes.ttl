ark:Arkivressurs a sh:NodeShape ;
    rdfs:comment "Ansatt med rolle og rettar innanfor arkiv." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class fint:Identifikator ;
            sh:description "Kildesystemets identifikator for arkivressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path ark:kildesystemId ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:class ark:Autorisasjon ;
            sh:description "Autorisasjonar gjevne til arkivressursen." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path ark:autorisasjon ],
        [ sh:class ark:Tilgang ;
            sh:description "Tilgangar gjevne til arkivressursen." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path ark:tilgang ],
        [ sh:description "Referanse til Personalressurs i Administrasjon-domenet." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
