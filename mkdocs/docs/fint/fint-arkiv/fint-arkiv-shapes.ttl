            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path ark:journalpost ],
        [ sh:class ark:Arkivressurs ;
            sh:description "Person som avslutta/lukka arkivenheten." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 24 ;
            sh:path ark:avsluttetAv ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Dato og klokkeslett arkivenheten vart oppretta/registrert." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
