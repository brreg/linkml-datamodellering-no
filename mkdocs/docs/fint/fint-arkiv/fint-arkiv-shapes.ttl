            sh:description "Organisasjonsnummer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ark:organisasjonsnummer ],
        [ sh:class fint:Kontaktinformasjon ;
            sh:description "Den føretrekte måten å kome i kontakt med ein aktør." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path fint:kontaktinformasjon ] ;
    sh:targetClass ark:Part .

ark:Arkivdel a sh:NodeShape ;
    rdfs:comment "Ein vilkårleg definert del av eit arkiv." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:datatype xsd:string ;
            sh:description "Tittel eller namn på arkivenheten." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ark:tittel ],
        [ sh:class ark:Klassifikasjonssystem ;
            sh:description "Klassifikasjonssystem." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path ark:klassifikasjonssystem ] ;
    sh:targetClass ark:Arkivdel .

ark:Skjerming a sh:NodeShape ;
    rdfs:comment "Skjerming av mappe, registrering eller dokument etter offentleglova." ;
