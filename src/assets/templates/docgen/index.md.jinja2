  {%- endif %}
{%- endfor -%}
{%- if ns_used_enums.names %}
| Enumeration | Description | Defined in | Usage |
| --- | --- | --- | --- |
{%- for enum_name in ns_used_enums.names|sort %}
  {%- set e = schemaview.get_enum(enum_name) %}
  {%- if e %}
    {%- set origin = e.from_schema if e.from_schema else schema.id %}
    {%- set is_used = namespace(value=false) -%}
    {%- for slot_name in (schema.slots or {}).keys() %}
      {%- set s = schemaview.get_slot(slot_name) %}
      {%- if s and s.range == enum_name %}
        {%- for class_name in schemaview.all_classes() %}
          {%- set c = schemaview.get_class(class_name) %}
          {%- set c_origin = c.from_schema if c.from_schema else schema.id %}
          {%- if c and not c.tree_root and c_origin == schema.id and slot_name in (c.slots or []) %}
            {%- set is_used.value = true -%}
          {%- endif %}
        {%- endfor %}
      {%- endif %}
    {%- endfor %}
    {# Sjekk om enum er brukt i ein lokal klasse (via induced_slot) #}
    {%- for class_name in schemaview.all_classes() %}
      {%- set c = schemaview.get_class(class_name) %}
      {%- set c_origin = c.from_schema if c.from_schema else schema.id %}
      {%- if c and not c.tree_root and c_origin == schema.id %}
        {%- for slot_name in c.slots or [] %}
          {%- set induced = schemaview.induced_slot(slot_name, class_name) %}
          {%- if induced and induced.range == enum_name %}
            {%- set is_used.value = true -%}
          {%- endif %}
        {%- endfor %}
      {%- endif %}
    {%- endfor %}
    {%- if is_used.value -%}
      {%- set usage_badge = "✅ Used" -%}
    {%- else -%}
      {%- set usage_badge = "⚠️ Defined" -%}
    {%- endif %}
| {{ gen.link(e, True) }} | {{ e.description|enshorten }} | {{ origin }} | {{ usage_badge }} |
