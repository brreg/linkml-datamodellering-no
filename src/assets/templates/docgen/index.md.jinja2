| Type | URI | Description | Defined in | Usage |
| --- | --- | --- | --- | --- |
{%- for type_name in ns_used_types.names|sort -%}
  {%- set t = schemaview.get_type(type_name) -%}
  {%- if t -%}
    {%- set origin = t.from_schema if t.from_schema else schema.id -%}
    {%- if t.uri and t.uri.startswith('xsd:') -%}
      {%- set local_name = t.uri[4:] -%}
      {%- set uri_text = t.uri -%}
      {%- set uri_link = 'https://www.w3.org/TR/xmlschema11-2/#' + local_name -%}
    {%- elif t.uri -%}
      {%- set uri_text = t.uri -%}
      {%- set uri_link = t.uri -%}
    {%- else -%}
      {%- set uri_text = type_name -%}
      {%- set uri_link = '#' -%}
    {%- endif -%}
    {%- set defined_in_text = origin -%}
    {%- set defined_in_link = origin -%}
    {%- if 'linkml/types' in origin or origin == 'https://w3id.org/linkml/types' -%}
      {%- set defined_in_text = 'linkml:types' -%}
      {%- set defined_in_link = 'https://github.com/linkml/linkml-model/blob/main/linkml_model/model/schema/types.yaml' -%}
    {%- endif %}
    {%- set is_used = namespace(value=false) -%}
    {# Sjekk om typen er brukt i ein lokal slot (definert i schema.slots) #}
    {%- for slot_name in (schema.slots or {}).keys() %}
      {%- set s = schemaview.get_slot(slot_name) %}
      {%- if s and s.range == type_name %}
        {%- set is_used.value = true -%}
      {%- endif %}
    {%- endfor %}
    {# Sjekk om typen er brukt i ein lokal klasse (via induced_slot) #}
    {%- for class_name in schemaview.all_classes() %}
      {%- set c = schemaview.get_class(class_name) %}
      {%- set c_origin = c.from_schema if c.from_schema else schema.id %}
      {%- if c and not c.tree_root and c_origin == schema.id %}
        {%- for slot_name in c.slots or [] %}
          {%- set induced = schemaview.induced_slot(slot_name, class_name) %}
          {%- if induced and induced.range == type_name %}
            {%- set is_used.value = true -%}
          {%- endif %}
        {%- endfor %}
      {%- endif %}
    {%- endfor %}
    {%- if is_used.value -%}
      {%- set usage_badge = "✅ Used" -%}
    {%- else -%}
      {%- set usage_badge = "⚠️ Defined" -%}
    {%- endif %}
| {{ type_name }} | [{{ uri_text }}]({{ uri_link }}) | {{ t.description|enshorten }} | [{{ defined_in_text }}]({{ defined_in_link }}) | {{ usage_badge }} |
  {%- endif -%}
{%- endfor %}
{% else %}
*Ingen typar brukt i denne modellen.*
