## Enumerations
{%- set ns_used_enums = namespace(names=[]) -%}
{# Samle alle enums brukt i slots #}
{%- for slot_name in ns_used_slots.names %}
  {%- set s = schemaview.get_slot(slot_name) %}
  {%- if s and s.range and schemaview.get_enum(s.range) %}
    {%- if s.range not in ns_used_enums.names %}
      {%- set ns_used_enums.names = ns_used_enums.names + [s.range] %}
    {%- endif %}
  {%- endif %}
{%- endfor -%}
{%- for class_name in schemaview.all_classes() %}
  {%- set c = schemaview.get_class(class_name) %}
  {%- set class_origin = c.from_schema if c.from_schema else schema.id %}
  {%- if c and not c.tree_root and class_origin == schema.id %}
    {%- for slot_name in c.slots or [] %}
      {%- set induced = schemaview.induced_slot(slot_name, class_name) %}
      {%- if induced and induced.range and schemaview.get_enum(induced.range) %}
        {%- if induced.range not in ns_used_enums.names %}
          {%- set ns_used_enums.names = ns_used_enums.names + [induced.range] %}
        {%- endif %}
      {%- endif %}
    {%- endfor %}
  {%- endif %}
{%- endfor -%}
