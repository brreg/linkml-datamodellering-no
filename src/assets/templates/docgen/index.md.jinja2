  {%- if c and not c.tree_root and class_origin == schema.id %}
    {%- for slot_name in c.slots or [] %}
      {%- set induced = schemaview.induced_slot(slot_name, class_name) %}
      {%- if induced and induced.range and schemaview.get_type(induced.range) %}
        {%- if induced.range not in ns_used_types.names %}
